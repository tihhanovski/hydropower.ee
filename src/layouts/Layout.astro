---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Hydropower OU | Hüdraulika ja pneumaatika lahendused',
	description = 'Hüdraulika ja pneumaatika komponentide müük, süsteemide koostamine, paigaldus, tarvikud ning nõustamine.'
} = Astro.props;
---

<!doctype html>
<html lang="et">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0f3d5a" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg: #f4f8fb;
		--bg-deep: #0f3d5a;
		--surface: #ffffff;
		--surface-alt: #e8f0f6;
		--text: #143347;
		--muted: #4f6677;
		--primary: #1d6d97;
		--accent: #ff8a30;
		--accent-soft: #ffd9bb;
		--border: #d2e0ea;
		--shadow: 0 18px 45px -28px rgba(16, 53, 77, 0.45);
		--radius-lg: 1.5rem;
		--radius-md: 1rem;
		--radius-sm: 0.75rem;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		font-family: 'Manrope', 'Segoe UI', sans-serif;
		background:
			radial-gradient(circle at 10% 0%, #d4ebff 0%, transparent 30%),
			radial-gradient(circle at 90% 20%, #ffe5cf 0%, transparent 28%),
			linear-gradient(180deg, #f7fbff 0%, #eff6fb 100%);
		color: var(--text);
		scroll-behavior: smooth;
	}

	body {
		min-height: 100vh;
		line-height: 1.6;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		max-width: 100%;
		display: block;
	}

	.container {
		width: min(1120px, 92vw);
		margin: 0 auto;
	}

	.section {
		padding: 5.5rem 0;
	}

	.section-title {
		font-family: 'Space Grotesk', 'Segoe UI', sans-serif;
		font-size: clamp(1.9rem, 3vw, 2.7rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin: 0 0 0.8rem;
	}

	.section-lead {
		margin: 0;
		max-width: 66ch;
		color: var(--muted);
		font-size: clamp(1rem, 1.8vw, 1.1rem);
	}

	.card {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow);
	}

	@media (max-width: 800px) {
		.section {
			padding: 4.2rem 0;
		}
	}
</style>
